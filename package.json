{
  "name": "btc-dashboard",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "lint": "eslint packages/*/src",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write packages/*/src",
    "format:check": "prettier --check packages/*/src",
    "typecheck": "pnpm --filter @btc-dashboard/server exec tsc --noEmit && pnpm --filter @btc-dashboard/client exec tsc --noEmit",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3"
  }
}
